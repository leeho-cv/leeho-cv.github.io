{
	"version": "2.0.0",
	"tasks": [
		{
			//"type": "cppbuild",
			"type": "shell",
			"label": "C: gcc.exe 生成活动文件(vc_c1)",
			"command": "D:\\mingw64\\bin\\gcc.exe",
			"args": [
				"-fdiagnostics-color=always",
				"-g",
				"${workspaceFolder}\\*.c",
				"-o",
				"${workspaceFolder}\\${workspaceRootFolderName}.exe"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "build",
			"detail": "编译器: D:\\mingw64\\bin\\gcc.exe"
		},
		{
			"type": "cppbuild",
			"label": "C: gcc.exe 生成活动文件(vc_c2)(default)",
			"command": "D:\\mingw64\\bin\\gcc.exe",
			"args": [
				"-fdiagnostics-color=always",
				"-g",
				"${workspaceFolder}\\*.c",
				"-o",
				"${workspaceFolder}\\${workspaceRootFolderName}.exe"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"detail": "编译器: D:\\mingw64\\bin\\gcc.exe"
		},
		{
			//"type": "cppbuild",
